# Optional: allow the simulator to exercise the live OpenAI Agents SDK path.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: set to 1 to use the live OpenAI path when OPENAI_API_KEY is present.
# Leave unset or 0 to keep simulator runs deterministic through the fallback path.
RELAI_SIMULATOR_ENABLE_LIVE_OPENAI=0
